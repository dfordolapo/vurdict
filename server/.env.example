# ── Environment Variables ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── AI Provider ──────────────────────────────────────────────────────────────
# Set to 'openai' (default) or 'gemini'
AI_PROVIDER=openai

# ── Required (at least one) ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Port the server listens on (default: 3001)
PORT=3001

# URL of the client dev server (for CORS)
CLIENT_URL=http://localhost:5173

# Jina Reader API key (optional — only needed to increase rate limits)
# JINA_API_KEY=your_jina_api_key_here

# Paystack secret key (required for payment verification)
# PAYSTACK_SECRET_KEY=sk_test_xxxxx

# Resend API key (required for sending report emails)
# RESEND_API_KEY=re_xxxxx
# FROM_EMAIL=reports@vurdict.vercel.app
